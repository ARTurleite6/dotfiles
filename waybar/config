{
    "position": "top",
    "layer": "top",
    "height": 16,
    "margin-top": 0,
    "margin-bottom": 0,
    "margin-left": 0,
    "margin-right": 0,
    "modules-left": ["custom/launcher", "hyprland/workspaces", "custom/playerctl", "custom/playerlabel"],
    "modules-center": ["cpu", "memory", "disk", "battery"],
    "modules-right": ["tray", "network", "pulseaudio", "clock"],
    // Modules configuration
	"clock": {
		"format": "{:%H:%M}",
		"tooltip": "true",
